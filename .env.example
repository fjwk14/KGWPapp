# ====== Meta / Instagram Graph API ======
# 取得手順は docs/SETUP_META.md を参照
# Instagram ビジネスアカウントのユーザーID（数値）
IG_USER_ID=

# 長期アクセストークン（60日有効。期限が近づいたら更新）
IG_ACCESS_TOKEN=

# Graph API のバージョン（省略時は既定値を使用）
GRAPH_API_VERSION=v21.0

# ====== 画像/動画の公開ホスティング ======
# Graph API は「公開URL」からしかメディアを取り込めないため、
# 生成した画像・リールを配置する公開ベースURLを指定します。
# 例: https://your-cdn.example.com/instagram
PUBLIC_MEDIA_BASE_URL=

# ====== AI コンテンツ生成（Anthropic Claude API）======
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=

# 生成に使うモデル（省略可）
CONTENT_MODEL=claude-sonnet-5
